# Скопируй в .env и заполни. НИКОГДА не коммить .env (он в .gitignore).

# --- Telegram ---
BOT_TOKEN=123456789:REPLACE_WITH_BOTFATHER_TOKEN
GROUP_CHAT_ID=-1001234567890         # forum-группа «Development»
ALLOWED_USERS=000000000             # CSV твоих Telegram user-id, кому разрешён доступ

# --- дефолты движка ---
DEFAULT_CWD=$HOME/projects
DEFAULT_MODEL=sonnet                 # sonnet | opus | haiku

# --- watchdog ---
STALL_SECONDS=300                    # нет событий N сек -> прервать агента
MAX_SECONDS=1800                     # общий потолок задачи (30 мин)

# --- браузерный кокпит ---
WEB_PORT=8787
WEB_PASSWORD=CHANGE_ME               # стойкий пароль; кокпит публичен через туннель
WEB_COOKIE_SALT=CHANGE_ME_RANDOM     # случайная строка; авто-генерируется при первом запуске

# --- персонализация (опционально) ---
# VAULT_PROJECTS=                    # абсолютный путь к папке с проектами в vault; пусто = фича отключена
OPERATOR_NAME=the operator           # имя оператора для nudge-промпта; подставляется вместо хардкода
RESPONSE_LANGUAGE=                   # язык ответов агента (напр. ru, en); пусто = без языковой директивы
