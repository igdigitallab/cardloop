# Copy to .env and fill in values.  NEVER commit .env (it is gitignored).
# Minimal run: CLAUDE_AUTH_MODE + WEB_PASSWORD + WEB_PORT — then open http://localhost:8787.

# --- Claude auth ---
# subscription (default): uses OAuth credentials from ~/.claude/.credentials.json (Claude subscription).
#   ANTHROPIC_API_KEY is forcibly removed to prevent accidental API billing.
# api_key: passes ANTHROPIC_API_KEY through to the SDK. ⚠️  THIS BILLS THE ANTHROPIC API.
CLAUDE_AUTH_MODE=subscription

# Optional: path to Claude OAuth credentials file.
# Leave empty to use the default ~/.claude/.credentials.json.
# CLAUDE_CREDENTIALS_PATH=

# Required only when CLAUDE_AUTH_MODE=api_key:
# ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram: REMOVED in v1.0 ---
# Cardloop is now web-only (PWA) + kanban auto-run. The Telegram channel was
# removed (spec-040). For the legacy Telegram-enabled version, use tag v0.13.x.

# --- engine defaults ---
DEFAULT_CWD=$HOME/projects
# Conductor pattern: fable acts as orchestrator, delegating heavy work to executor/researcher/quick
# sub-agents (sonnet/haiku) via the SDK Task tool. Change to sonnet/opus/haiku to disable.
# Requires claude CLI >= the version that recognises the "fable" alias; falls back to opus otherwise.
DEFAULT_MODEL=fable                  # fable (conductor) | sonnet | opus | haiku

# Sub-agent models (used by DEFAULT_AGENTS roster — Phase B, spec-017).
# Override per-agent via env; per-project overrides: Phase C.
EXECUTOR_MODEL=sonnet                # executor sub-agent model
RESEARCHER_MODEL=sonnet              # researcher sub-agent model (read-only: no Write/Edit)
QUICK_MODEL=haiku                    # quick sub-agent model (fast/cheap lookups)
DEFAULT_EFFORT=medium                # conductor effort level: low|medium|high|xhigh|max (default: medium)

# --- watchdog ---
STALL_SECONDS=300                    # interrupt agent after N seconds with no SDK events
MAX_SECONDS=1800                     # hard task time-limit (30 min)

# --- web cockpit ---
WEB_PORT=8787
WEB_PASSWORD=CHANGE_ME               # strong password; cockpit is public if tunnelled
WEB_COOKIE_SALT=CHANGE_ME_RANDOM     # random string; auto-generated on first run if missing

# WEB_HOST: interface to bind on.
# 127.0.0.1 (default) = local only, safe.
# 0.0.0.0 = all interfaces (LAN / reverse proxy).  Do NOT expose to the internet without HTTPS.
WEB_HOST=127.0.0.1

# WEB_COOKIE_SECURE: set to true only when serving over HTTPS (reverse proxy / Cloudflare Tunnel).
# Must be false for plain http://LAN-IP:PORT access — browsers silently drop Secure cookies
# over http, which makes login appear broken with no error message.
WEB_COOKIE_SECURE=false

# TRUSTED_PROXIES: comma-separated proxy IPs/CIDRs. When set, the login rate-limiter
# trusts CF-Connecting-IP / X-Forwarded-For ONLY from these direct peers (so it sees
# the real client IP behind a reverse proxy). Empty (default) = ignore those headers
# and rate-limit by the socket peer. Behind Docker/Traefik, e.g. 172.16.0.0/12.
# TRUSTED_PROXIES=

# --- personalisation (optional) ---
# VAULT_PROJECTS=                    # absolute path to vault projects folder; empty = feature disabled
OPERATOR_NAME=the operator           # operator name injected into the TG nudge prompt
RESPONSE_LANGUAGE=                   # agent reply language (e.g. "по-русски", "in English"); empty = no directive

# --- persistent client (Spec 028) ---
# PERSISTENT_CLIENT=0                 # 1 = reuse ClaudeSDKClient across turns per session (experimental); 0 = off (default)
# LIVE_CLIENT_TTL_SEC=600             # idle seconds before an unused live client is evicted (default 600 = 10 min)
# LIVE_CLIENT_MAX=10                  # max concurrent live clients held in registry; LRU eviction beyond this

# --- schedules registry (Spec 019) ---
SCHEDULES_SCAN_INTERVAL=300          # seconds between automatic schedule scans (default 300 = 5 min)
# Coolify integration (optional): if set, the Coolify scheduled-tasks API is queried on each scan.
# COOLIFY_API_TOKEN=                 # Bearer token from Coolify Settings > API Keys
# COOLIFY_SERVER_UUID=               # Server UUID from Coolify (visible in server settings)
# COOLIFY_API_BASE=http://localhost:8000/api/v1  # Coolify API base URL (default: local)
# n8n integration (optional): if set, active n8n workflows with schedule triggers are collected.
# N8N_API_KEY=                       # n8n API key (Settings > n8n API)
# N8N_HOST=localhost:5678             # n8n host:port (default: localhost:5678)

# --- deferred runs (Spec 020 Phases A-C) ---
# DEFERRED_POLL_SEC=30               # how often the deferred-runs loop checks for due records (seconds)
# DEFERRED_MAX_ATTEMPTS=5            # max fire attempts per deferred record before marking it failed
# DEFERRED_FREE_THRESHOLD=0.10       # fire_on_reset fires early if window utilization drops below this fraction

# --- auto-resume on rate-limit (Spec 020 Phase D) ---
AUTO_RESUME_ON_RATE_LIMIT=1          # 1 = auto-queue a fire_on_reset deferred run when a run dies rate-limited (429); 0 = off
AUTO_RESUME_MAX=3                    # max consecutive auto-resumes per chain; at limit → TG warning, manual restart required

# --- context rotation (Spec 021) ---
# CONTEXT_ROTATION=1                 # 1 = auto-rotate session when token threshold is exceeded; 0 = disabled
# CONTEXT_ROTATE_AT=60000            # token count that triggers auto-rotation (default 60 000 = 60K)
