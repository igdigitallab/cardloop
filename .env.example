# Copy to .env and fill in values.  NEVER commit .env (it is gitignored).
# Minimal run: CLAUDE_AUTH_MODE + WEB_PASSWORD + WEB_PORT — then open http://localhost:8787.
#
# NOTE: keep every value on its own line with NO trailing inline comment.
# systemd's EnvironmentFile= parser does NOT strip inline "# ..." comments — it
# would fold them into the value (e.g. SCHEDULES_SCAN_INTERVAL="300  # ...") and
# break startup. Comments therefore live on their own lines, above each setting.

# --- Claude auth ---
# subscription (default): uses OAuth credentials from ~/.claude/.credentials.json (Claude subscription).
#   ANTHROPIC_API_KEY is forcibly removed to prevent accidental API billing.
# api_key: passes ANTHROPIC_API_KEY through to the SDK. ⚠️  THIS BILLS THE ANTHROPIC API.
CLAUDE_AUTH_MODE=subscription

# Optional: path to Claude OAuth credentials file.
# Leave empty to use the default ~/.claude/.credentials.json.
# CLAUDE_CREDENTIALS_PATH=

# Required only when CLAUDE_AUTH_MODE=api_key:
# ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram: REMOVED in v1.0 ---
# Cardloop is now web-only (PWA) + kanban auto-run. The Telegram channel was
# removed (spec-040). For the legacy Telegram-enabled version, use tag v0.13.x.

# --- engine defaults ---
DEFAULT_CWD=$HOME/projects
# Conductor pattern: fable acts as orchestrator, delegating heavy work to executor/researcher/quick
# sub-agents (sonnet/haiku) via the SDK Task tool. Change to sonnet/opus/haiku to disable.
# Requires claude CLI >= the version that recognises the "fable" alias; falls back to opus otherwise.
# Options: fable (conductor) | sonnet | opus | haiku
DEFAULT_MODEL=fable

# Sub-agent models (used by DEFAULT_AGENTS roster — Phase B, spec-017).
# Override per-agent via env; per-project overrides: Phase C.
# executor sub-agent model
EXECUTOR_MODEL=sonnet
# researcher sub-agent model (read-only: no Write/Edit)
RESEARCHER_MODEL=sonnet
# quick sub-agent model (fast/cheap lookups)
QUICK_MODEL=haiku
# conductor effort level: low|medium|high|xhigh|max (default: medium)
DEFAULT_EFFORT=medium

# --- watchdog ---
# interrupt agent after N seconds with no SDK events
STALL_SECONDS=300
# hard task time-limit in seconds (1800 = 30 min)
MAX_SECONDS=1800

# --- web cockpit ---
WEB_PORT=8787
# strong password; cockpit is public if tunnelled (CHANGE_ME is rejected at startup)
WEB_PASSWORD=CHANGE_ME
# random string; auto-generated on first run if missing
WEB_COOKIE_SALT=CHANGE_ME_RANDOM

# WEB_HOST: interface to bind on.
# 127.0.0.1 (default) = local only, safe.
# 0.0.0.0 = all interfaces (LAN / reverse proxy).  Do NOT expose to the internet without HTTPS.
WEB_HOST=127.0.0.1

# WEB_COOKIE_SECURE: set to true only when serving over HTTPS (reverse proxy / Cloudflare Tunnel).
# Must be false for plain http://LAN-IP:PORT access — browsers silently drop Secure cookies
# over http, which makes login appear broken with no error message.
WEB_COOKIE_SECURE=false

# TRUSTED_PROXIES: comma-separated proxy IPs/CIDRs. When set, the login rate-limiter
# trusts CF-Connecting-IP / X-Forwarded-For ONLY from these direct peers (so it sees
# the real client IP behind a reverse proxy). Empty (default) = ignore those headers
# and rate-limit by the socket peer. Behind a Cloudflare Tunnel use 127.0.0.1;
# behind Docker/Traefik, e.g. 172.16.0.0/12.
# TRUSTED_PROXIES=

# --- personalisation (optional) ---
# VAULT_PROJECTS: absolute path to vault projects folder; empty = feature disabled
# VAULT_PROJECTS=
# operator name injected into the nudge prompt
OPERATOR_NAME=the operator
# agent reply language (e.g. "in Russian", "in English"); empty = no directive
RESPONSE_LANGUAGE=
# OPERATOR_TZ: timezone for displayed times (e.g. rate-limit reset); default UTC
# OPERATOR_TZ=UTC

# --- second opinion via Antigravity (spec-060, optional) ---
# Exposes a `second_opinion` tool that lets the agent consult a different model family
# (Google Gemini / GPT-OSS / Claude-via-Google) through the `agy` CLI, billed to the
# Google AI Pro quota instead of the Anthropic subscription. Auto-enabled ONLY when the
# `agy` binary is found; if it is absent the tool simply never appears.
# 1 = expose second_opinion when agy is present; 0 = off
SECOND_OPINION=1
# AGY_BIN: path to the agy binary (default: `which agy`, then ~/.local/bin/agy)
# AGY_BIN=
# seconds before an agy call is killed
SECOND_OPINION_TIMEOUT=180
# truncate the other model's answer to protect Claude's context
SECOND_OPINION_MAX_CHARS=6000

# --- persistent client (Spec 028) ---
# PERSISTENT_CLIENT: 1 = reuse ClaudeSDKClient across turns per session (experimental); 0 = off (default)
# PERSISTENT_CLIENT=0
# LIVE_CLIENT_TTL_SEC: idle seconds before an unused live client is evicted (default 600 = 10 min)
# LIVE_CLIENT_TTL_SEC=600
# LIVE_CLIENT_MAX: max concurrent live clients held in registry; LRU eviction beyond this
# LIVE_CLIENT_MAX=10

# --- schedules registry (Spec 019) ---
# seconds between automatic schedule scans (default 300 = 5 min)
SCHEDULES_SCAN_INTERVAL=300
# Coolify integration (optional): if set, the Coolify scheduled-tasks API is queried on each scan.
# COOLIFY_API_TOKEN: Bearer token from Coolify Settings > API Keys
# COOLIFY_API_TOKEN=
# COOLIFY_SERVER_UUID: Server UUID from Coolify (visible in server settings)
# COOLIFY_SERVER_UUID=
# COOLIFY_API_BASE: Coolify API base URL (default: local)
# COOLIFY_API_BASE=http://localhost:8000/api/v1
# n8n integration (optional): if set, active n8n workflows with schedule triggers are collected.
# N8N_API_KEY: n8n API key (Settings > n8n API)
# N8N_API_KEY=
# N8N_HOST: n8n host:port (default: localhost:5678)
# N8N_HOST=localhost:5678

# --- deferred runs (Spec 020 Phases A-C) ---
# DEFERRED_POLL_SEC: how often the deferred-runs loop checks for due records (seconds)
# DEFERRED_POLL_SEC=30
# DEFERRED_MAX_ATTEMPTS: max fire attempts per deferred record before marking it failed
# DEFERRED_MAX_ATTEMPTS=5
# DEFERRED_FREE_THRESHOLD: fire_on_reset fires early if window utilization drops below this fraction
# DEFERRED_FREE_THRESHOLD=0.10

# --- auto-resume on rate-limit (Spec 020 Phase D) ---
# 1 = auto-queue a fire_on_reset deferred run when a run dies rate-limited (429); 0 = off
AUTO_RESUME_ON_RATE_LIMIT=1
# max consecutive auto-resumes per chain; at limit → cockpit warning, manual restart required
AUTO_RESUME_MAX=3

# --- context rotation (cost cap) ---
# Auto-rotation at the cost cap is OFF by default and opt-in PER CHAT (composer "+" menu toggle).
# CONTEXT_ROTATION: global kill-switch for the per-chat auto-rotation (default on; 0 = hard-disable)
# CONTEXT_ROTATION=1
# CONTEXT_ROTATE_AT: tokens that trigger auto-rotation when a chat opts in (default 280K)
# CONTEXT_ROTATE_AT=280000
# CONTEXT_WARN_AT: ambient "getting expensive" banner threshold (default 200K)
# CONTEXT_WARN_AT=200000

# --- Web Push (spec-053 Phase B) ---
# VAPID subject: identifies your service to push gateways. Use mailto: or https: URI.
VAPID_SUBJECT=mailto:you@example.com

# --- systemd service/unit name ---
# CARDLOOP_SERVICE: unit name used by restart-self.sh / update.sh (OSS default: cardloop)
# CARDLOOP_SERVICE=cardloop
